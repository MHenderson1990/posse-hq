MONGO_URI=mongodb+srv://user:password@your-cluster.mongodb.net/posse-hq
JWT_SECRET=replace-with-a-long-random-string
PORT=4000

# APNs (push notifications) — from your Apple Developer account's Keys section.
# On Render, upload the .p8 as a Secret File and point APNS_KEY_PATH at its mounted path
# (e.g. /etc/secrets/AuthKey_XXXXXXXXXX.p8). Locally it's just a relative path to the file.
# Leave these unset to fall back to logging notifications instead of sending them.
APNS_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.possehq.app
# sandbox while testing via Xcode/TestFlight-less dev builds; production once on the App Store
APNS_ENV=sandbox
